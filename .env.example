# MCP Hub Environment Configuration
# ⚠️  DO NOT put real secrets here. Copy to .env and use gitignored local file.
#
# How secrets are handled in this project:
#   • Local dev:    place real values in ./.env (gitignored)
#   • CI / deploy:  inject via GitHub Actions secrets, Netlify/Vercel env vars
#   • Never commit: any real API key, token, password, or PII
#
# Copy this file to .env and modify as needed.

# ─── Backend Configuration ──────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
CORS_ALLOW_ALL=false
PORT=8080
HOST=0.0.0.0

# ─── Frontend Configuration (Vite) ──────────────────────────────────────────
VITE_API_URL=/api
VITE_APP_NAME=MCP Hub
VITE_APP_VERSION=2.0.1

# ─── Optional Integrations (only set if needed) ────────────────────────────
# GitHub API rate-limit boost (optional, public read access needs no token)
# GITHUB_TOKEN=

# AI-assisted features (optional)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

