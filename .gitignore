# ─── Environment & Secrets ────────────────────────────────────────────────
# Local environment files (NEVER commit real values)
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test

# Secret / credential files
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
*.der
*.asc
id_rsa
id_dsa
id_ecdsa
id_ed25519
*.gpg
.gpg/
.gnupg/

# Auth helpers
.git_askpass_tmp.sh
.netrc
.htpasswd
.secrets

# IDE / tool secrets
.vscode/settings.json
.idea/workspace.xml

# Cloud / provider credentials
.aws/
.azure/
.gcp/
.gcloud/
.kube/
.kubectl/

# ─── Python ───────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
*.egg-info/
dist/
build/

# ─── Node.js ──────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-store/

# ─── Frontend build outputs ───────────────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.vite/

# ─── IDE ──────────────────────────────────────────────────────────────────
# Track shared team configs (settings.json + extensions.json) but ignore
# machine-local files. Anything user-specific should land in
# `.vscode/settings.local.json` (gitignored) instead.
.vscode/
!.vscode/settings.json
!.vscode/settings.local.json
!.vscode/extensions.json
!.vscode/launch.json
.idea/
*.swp
*.swo
*.swn

# ─── OS ───────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# ─── Generated files ──────────────────────────────────────────────────────
# NOTE: frontend/public/servers-index.json IS tracked (the GH Pages
# build won't have a data file otherwise). It is rebuilt daily by
# .github/workflows/sync-data.yml and committed back to main; the
# commit history is the data history. Size is ~4.4MB which is
# acceptable for a single binary blob.
#
# market-index.json, user-data.json, submissions.json remain
# un-tracked (legacy artefacts, not used by the static SPA anymore).
market-index.json
user-data.json
submissions.json
# The root servers-index.json (output of sync_index.py) is an
# intermediate; the SPA reads from frontend/public/servers-index.json
# which is what gets committed. So we keep the root one out.
/servers-index.json
!/frontend/public/servers-index.json
.pytest_cache/
.coverage
htmlcov/
.coverage.*

# ─── TRAE / AI IDE specific ───────────────────────────────────────────────
.trae/

# ─── Cache files ──────────────────────────────────────────────────────────
*.cache
.pytest_cache/
.mypy_cache/
.pytype/
ruff_cache/
.eslintcache
.parcel-cache/

# ─── Logs ─────────────────────────────────────────────────────────────────
*.log
logs/

