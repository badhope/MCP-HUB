# Frontend Environment Configuration
# ⚠️  DO NOT put real secrets here. Copy to .env (gitignored) for local use.
#
# Copy to .env for local development
# VITE_API Base URL - uses proxy in dev, direct URL in production
#
# Both VITE_BASE_PATH and VITE_API_PROXY_TARGET are also read by vite.config.ts;
# they default to `/MCP-HUB/` and `http://localhost:8080` respectively when unset.

VITE_API_URL=/api
VITE_APP_NAME=MCP Hub
VITE_APP_VERSION=2.0.1

# Override the asset base path. Default `/MCP-HUB/`. Useful when previewing
# the built bundle outside of GitHub Pages.
# VITE_BASE_PATH=/MCP-HUB/

# Override the dev-server proxy target for `/api/*`. Default `http://localhost:8080`.
# VITE_API_PROXY_TARGET=http://localhost:8080

# Optional integrations (set in local .env only, never commit values)
# VITE_GITHUB_TOKEN=
# VITE_SENTRY_DSN=

