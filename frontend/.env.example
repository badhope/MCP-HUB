# Frontend Environment Configuration
# ⚠️  DO NOT put real secrets here. Copy to .env (gitignored) for local use.
#
# Copy to .env for local development
# VITE API Base URL - uses proxy in dev, direct URL in production

VITE_API_URL=/api
VITE_APP_NAME=MCP Hub
VITE_APP_VERSION=2.0.1

