# Frontend Environment Configuration
# ⚠️  DO NOT put real secrets here. Copy to .env (gitignored) for local use.
#
# Phase 6+: the FastAPI backend is gone. Everything is static.
# VITE_API_URL is no longer honoured — the SPA reads from
# `frontend/public/servers-index.json` and writes user data to localStorage.

VITE_APP_NAME=MCP Hub
VITE_APP_VERSION=3.0.0

# Override the asset base path. Default `/MCP-HUB/`. Useful when previewing
# the built bundle outside of GitHub Pages.
# VITE_BASE_PATH=/MCP-HUB/

# Optional integrations (set in local .env only, never commit values)
# VITE_SENTRY_DSN=
